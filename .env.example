# ══════════════════════════════════════════════════════════════
# KOBWEBSITE-1.2 Environment Variables
# Copy this file to .env and fill in the values
# ══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Session encryption key (generate with: openssl rand -base64 32)
SESSION_SECRET="your-session-secret-here"

# ── AI / LLM Keys ────────────────────────────────────────────

# Anthropic Claude API (replacing OpenAI for text generation)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (legacy — being migrated to Claude)
AI_INTEGRATIONS_OPENAI_API_KEY="sk-..."
AI_INTEGRATIONS_OPENAI_BASE_URL="https://api.openai.com/v1"
# Fallback key used by workshop/Donna AI
OPENAI_API_KEY="sk-..."

# Google Gemini (used for image description generation)
GEMINI_API_KEY="AIza..."

# ── Image Generation ─────────────────────────────────────────

# Leonardo AI (blog post header images)
LEONARDO_API_KEY=""

# Replicate (Flux LORA image generation)
REPLICATE_API_TOKEN=""

# ── Voice / Audio ─────────────────────────────────────────────

# ElevenLabs (MicroPod text-to-speech — pending)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# ── Email ─────────────────────────────────────────────────────

# Resend (newsletter email sending)
RESEND_API_KEY="re_..."

# ── Admin Authentication ──────────────────────────────────────

# Admin keys for Content Studio, Newsletter, Pain Points
NEWSLETTER_ADMIN_KEY="your-admin-key"
KIANNA_ADMIN_KEY=""
AUDREY_ADMIN_KEY=""

# ── Server Configuration ──────────────────────────────────────

# Port (Railway sets this automatically, default 3001 for local dev)
PORT="3001"

# Environment
NODE_ENV="development"

# Log level (debug, info, warn, error)
LOG_LEVEL="info"

# ── Replit Auth (legacy — only needed if running on Replit) ───

# REPL_ID=""
# ISSUER_URL="https://replit.com/oidc"
